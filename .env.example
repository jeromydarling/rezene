# Copy the secret values into `.dev.vars` for local Worker dev
# (wrangler/vite read .dev.vars — see .dev.vars.example) and set them in
# production with `wrangler secret put <NAME>`.
# Never commit real keys. Never expose secret keys to the browser.

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
ANTHROPIC_API_KEY=
RESEND_API_KEY=
APP_ENV=development
APP_URL=http://localhost:5173
ADMIN_EMAIL=
SESSION_SECRET=
R2_PUBLIC_BASE_URL=
