{
  "name": "maison-atlantique",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Cloudflare-native brand OS and DTC commerce platform for a Morocco-produced Atlantic Riviera clothing brand.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "tsc -b --noEmit",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply maison-atlantique-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply maison-atlantique-db --remote",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "lucide-react": "^0.468.0",
    "mimetext": "^3.0.28",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.1.0",
    "stripe": "^18.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.20250405.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
