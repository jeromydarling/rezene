# Local Worker secrets — copy to `.dev.vars` (gitignored) and fill in.
# Production equivalents: `wrangler secret put <NAME>`.

# Local dev mode (wrangler.toml ships APP_ENV=production for deploys).
APP_ENV=development

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
ANTHROPIC_API_KEY=sk-ant-...
SESSION_SECRET=generate-a-long-random-string
ADMIN_EMAIL=founder@example.com
# Password for the seeded admin user is set on first login bootstrap — see README "Admin seed login".
ADMIN_INITIAL_PASSWORD=change-me-immediately
